# Database (this agent's own DB — NOT Maya's)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/maya_calendar

# Maya integration (get these from Maya's admin panel)
MAYA_CLIENT_ID=
MAYA_CLIENT_SECRET=
MAYA_API_URL=http://localhost:8000

# LLM provider ("openai" or "anthropic")
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Google Calendar OAuth (optional — leave empty to disable sync)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8001/api/google/callback
# Token encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TOKEN_ENCRYPTION_KEY=

# App
DEBUG=true
